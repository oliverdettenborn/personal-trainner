{
  "name": "personal-trainner",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "concurrently -n supabase,expo -c cyan,magenta \"supabase start\" \"expo start\"",
    "db": "supabase start",
    "studio": "start http://127.0.0.1:54323",
    "mail": "start http://127.0.0.1:54324",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port 8081",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:cypress": "tsc -p cypress/tsconfig.json",
    "test:e2e": "wait-on tcp:127.0.0.1:8081 --timeout 5000 && cypress open || start-server-and-test 'npm run web' tcp:127.0.0.1:8081 'cypress open'",
    "test:e2e:run": "wait-on tcp:127.0.0.1:8081 --timeout 5000 && cypress run || start-server-and-test 'node scripts/start-web-silent.js' tcp:127.0.0.1:8081 'cypress run'",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.105.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "html2canvas": "^1.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.0",
    "@types/html2canvas": "^0.5.35",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "cypress": "^15.14.2",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^15.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.4",
    "pg-mem": "^3.0.14",
    "react-test-renderer": "^19.1.0",
    "serve": "^14.2.6",
    "start-server-and-test": "^3.0.2",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.5"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": []
  },
  "private": true,
  "engines": {
    "node": ">=24"
  }
}
